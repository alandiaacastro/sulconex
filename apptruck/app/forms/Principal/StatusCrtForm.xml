<?xml version="1.0" encoding="UTF-8"?>
<tpage>
  <tform>
    <tformheader>
      <trow>
        <tcolumn col="col-10">
          <tlabel label="[page_name]" color="#333333" font_style="b" font_size=""/>
        </tcolumn>
        <tcolumn col="col-2">
          <tbutton label="Fechar" button_class="danger" action_class="" action_method="" action_js="Template.closeRightPanel()" style="float:right" register_state="N" static_call="N" custom_params=""/>
        </tcolumn>
      </trow>
    </tformheader>
    <tformbody>
      <trow>
        <tcolumn col="col-12">
          <tnotebook>
            <ttab name="Dados">
              <trow>
                <tcolumn col="col-12">
                  <tlabel label="Id" color="#333333" font_style="b"/>
                  <tentry name="id" required="N" label_required="Id" editable="N" width="100%" style=""/>
                </tcolumn>
              </trow>
              <trow>
                <tcolumn col="col-12">
                  <tlabel label="Nome" color="#333333" font_style="b"/>
                  <tentry name="nome" required="N" label_required="Nome" editable="Y" width="100%" style=""/>
                </tcolumn>
              </trow>
              <trow>
                <tcolumn col="col-12">
                  <tlabel label="Cor" color="#333333" font_style="b"/>
                  <tcolor name="cor" required="N" label_required="" editable="Y" value="" value_dynamic="" placeholder="" tooltip="" change_action="" style="" css_class=""/>
                </tcolumn>
              </trow>
            </ttab>
          </tnotebook>
        </tcolumn>
      </trow>
    </tformbody>
    <tformfooter>
      <trow>
        <tcolumn col="col-6">
          <tbutton label="Salvar" button_class="primary" action_class="StatusCrtForm" action_method="onSave" action_js="" register_state="N" static_call="Y" http_method="post" custom_params="" style=""/>
        </tcolumn>
        <tcolumn col="col-6">
        </tcolumn>
      </trow>
    </tformfooter>
  </tform>
</tpage>
