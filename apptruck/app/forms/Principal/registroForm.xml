<?xml version="1.0" encoding="UTF-8"?>
<tpage>
  <tform>
    <tformheader>
      <trow>
        <tcolumn col="col-10">
          <tlabel label="[page_name]" color="#333333" font_style="b" font_size=""/>
        </tcolumn>
        <tcolumn col="col-2">
          <tbutton label="Fechar" button_class="danger" action_class="" action_method="" action_js="Template.closeRightPanel()" style="float:right" register_state="N" static_call="N" custom_params=""/>
        </tcolumn>
      </trow>
    </tformheader>
    <tformbody>
      <trow>
        <tcolumn col="col-12">
          <tnotebook>
            <ttab name="Dados">
              <trow>
                <tcolumn col="col-3">
                  <tlabel label="Id" color="#333333" font_style="b"/>
                  <tentry name="id" required="N" label_required="Id" editable="N" value="" value_dynamic="" maxlen="0" placeholder="" tooltip="" force_case="" mask="" exit_action="" exit_on_enter="N" style="" css_class=""/>
                </tcolumn>
                <tcolumn col="col-3">
                  <tlabel label="CNPJ" color="#333333" font_style="b" font_size="" css_class=""/>
                  <tentry name="cnpj" required="N" label_required="" editable="Y" value="" value_dynamic="" maxlen="0" placeholder="" tooltip="" force_case="" mask="" exit_action="" exit_on_enter="N" style="" css_class=""/>
                </tcolumn>
                <tcolumn col="col-6">
                  <tlabel label="Nome" color="#333333" font_style="b" font_size="" css_class=""/>
                  <tentry name="nometransportadora" required="N" label_required="" editable="Y" value="" value_dynamic="" maxlen="0" placeholder="" tooltip="" force_case="" mask="" exit_action="" exit_on_enter="N" style="" css_class=""/>
                </tcolumn>
              </trow>
              <trow>
                <tcolumn col="col-12">
                  <wrapper>
                    <trow>
                      <tcolumn col="col-3">
                        <tlabel label="registro" color="#333333" font_style="b" font_size="" css_class=""/>
                        <tentry name="codigo" required="N" label_required="" editable="Y" value="" value_dynamic="" maxlen="0" placeholder="" tooltip="" force_case="" mask="" exit_action="" exit_on_enter="N" style="" css_class=""/>
                      </tcolumn>
                      <tcolumn col="col-3">
                        <tlabel label="Numerocrt" color="#333333" font_style="b"/>
                        <tentry name="sequenciacrt" required="N" label_required="Numerocrt" editable="Y" value="" value_dynamic="" maxlen="0" placeholder="" tooltip="" force_case="" mask="" exit_action="" exit_on_enter="N" style="" css_class=""/>
                      </tcolumn>
                      <tcolumn col="col-3">
                        <tlabel label="enlastre" color="#333333" font_style="b" font_size="" css_class=""/>
                        <tentry name="enlastre" required="N" label_required="" editable="Y" value="" value_dynamic="" maxlen="0" placeholder="" tooltip="" force_case="" mask="" exit_action="" exit_on_enter="N" style="" css_class=""/>
                      </tcolumn>
                      <tcolumn col="col-3">
                        <tlabel label="Pais Destino" color="#333333" font_style="b"/>
                        <tentry name="pais_destino" required="N" label_required="" editable="Y" value="" value_dynamic="" maxlen="0" placeholder="" tooltip="" force_case="" mask="" exit_action="" exit_on_enter="N" style="" css_class=""/>
                      </tcolumn>
                    </trow>
                  </wrapper>
                  <tlabel label="Transportadora" color="#333333" font_style="b"/>
                  <ttext name="transportadora" required="N" label_required="Transportadora" editable="Y" value="" value_dynamic="" maxlen="0" placeholder="" tooltip="" height="200" force_case="" exit_action="" style="" css_class=""/>
                </tcolumn>
              </trow>
              <trow>
                <tcolumn col="col-12">
                  <tlabel label="Logo" color="#333333" font_style="b"/>
                  <tfile name="logo" required="N" label_required="" editable="Y" tooltip="" extensions="" save_path="files/images/logo/" file_handling="json" upload_limit="10" image_gallery="Y" enable_popover="N" complete_action=""/>
                </tcolumn>
              </trow>
            </ttab>
          </tnotebook>
          <wrapper>
          </wrapper>
        </tcolumn>
      </trow>
    </tformbody>
    <tformfooter>
      <trow>
        <tcolumn col="col-6">
          <tbutton label="Salvar" button_class="primary" action_class="registroForm" action_method="onSave" action_js="" register_state="N" static_call="Y" http_method="post" custom_params="" style=""/>
        </tcolumn>
        <tcolumn col="col-6">
        </tcolumn>
      </trow>
    </tformfooter>
  </tform>
</tpage>
