<?xml version="1.0" encoding="UTF-8"?>
<tpage>
  <tform>
    <tformheader>
      <trow>
        <tcolumn col="col-4">
          <tlabel label="[page_name]" color="#333333" font_style="b" font_size="medium"/>
        </tcolumn>
        <tcolumn col="col-8">
          <tbutton label="Novo" icon="fas fa-plus" button_class="success" action_class="registroForm" action_method="onEdit" register_state="N" static_call="N" http_method="get" preserve_params="" action_js="" style="float:right" custom_params=""/>
          <tbutton label="XLS" icon="fas fa-table" button_class="default" action_class="registroList" action_method="onExportXLS" register_state="N" static_call="Y" http_method="get" preserve_params="" action_js="" available_mobile="N" style="float:right" custom_params=""/>
          <tbutton label="PDF" icon="far fa-file-pdf" button_class="default" action_class="registroList" action_method="onExportPDF" register_state="N" static_call="Y" http_method="get" preserve_params="" action_js="" available_mobile="N" style="float:right" custom_params=""/>
          <tbutton label="Filtros" icon="fas fa-filter" button_class="default" action_class="registroList" action_method="onShowFilters" register_state="N" static_call="Y" http_method="get" preserve_params="" action_js="" style="float:right" custom_params=""/>
          <tbutton label="Colunas" icon="fas fa-columns" button_class="default" action_class="registroList" action_method="onSelectColumns" register_state="N" static_call="Y" http_method="get" preserve_params="" action_js="" available_mobile="N" style="float:right" custom_params="" use_popover="Y"/>
          <tcombo name="combo_limit" required="N" label_required="" editable="Y" value="{session_limit} ?? 10" value_dynamic="" tooltip="Registros por página" allow_null_option="Y" items="10:10#rn#20:20#rn#50:50#rn#100:100#rn#500:500#rn#1000:1000" items_dynamic="" boolean_mode="N" enable_search="N" change_action="onChangeLimit" style="float:right#rn#width:70px !important#rn#" css_class="hide-mobile input-sm"/>
        </tcolumn>
      </trow>
    </tformheader>
    <tformbody>
      <trow>
        <tcolumn col="col-12">
          <tdatagrid role="datagrid" db_order_col="[registro->id]" db_model="registro" db_order_dir="asc" page_records="10" page_navigation="Y" search_pack="curtain">
            <tdatagridaction color="#478FCA" icon="far fa-edit" label="Editar" action_class="registroForm" action_method="onEdit" register_state="N" static_call="N" custom_params=""/>
            <tdatagridaction color="#DD5A43" icon="far fa-trash-alt" label="Excluir" action_class="registroList" action_method="onDelete" preserve_params="offset, page, first_page" register_state="N" static_call="Y" custom_params=""/>
            <tdatagridcolumn title="Id" attribute="{id}" width="small" align="center" printable="Y" visible="Y" db_order_col="[registro->id]"/>
              <tdatagridcolumn attribute="{codigo}" title="Codigo Permisso" db_order_col="[registro->codigo]" width="small" align="left" visible="Y" printable="Y" filter_field="" transformation="" totalizer="" auto_hide=""/>
                <tdatagridcolumn attribute="{sequenciacrt}" title="Numerocrt" db_order_col="[registro->sequenciacrt]" width="small" align="left" visible="Y" printable="Y" filter_field="" transformation="" totalizer="" auto_hide=""/>
                  <tdatagridcolumn attribute="{pais_destino}" title="Pais Destino" db_order_col="[registro->pais_destino]" width="small" align="left" visible="Y" printable="N" filter_field="" transformation="" totalizer="" auto_hide=""/>
                    <tdatagridcolumn attribute="{nometransportadora}" title="nome transportadora" db_order_col="[registro->nometransportadora]" width="very_large" align="left" visible="Y" printable="Y" filter_field="" transformation="" totalizer="" auto_hide=""/>
                      <tdatagridfilter attribute="[registro->codigo]" operator="like" filter_type="formfield" formfield="codigo"/>
                        <tform role="search_form">
                          <tformbody>
                            <trow>
                              <tcolumn col="col-12">
                                <tlabel label="Codigo Permisso" color="#333333" font_style="b"/>
                                <ttext name="codigo" required="N" label_required="Codigo Permisso" editable="Y" width="100%" height="200" style=""/>
                              </tcolumn>
                            </trow>
                          </tformbody>
                        </tform>
                      </tdatagrid>
                    </tcolumn>
                  </trow>
                </tformbody>
                <tformfooter>
                </tformfooter>
              </tform>
            </tpage>
